{
  "name": "@dot-inc/dot-ocean",
  "private": true,
  "version": "3.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "build:lib": "vite build --config vite.config.lib.ts",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.1.1",
    "playwright": "^1.48.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "module": "dist-sdk/dot-ocean.mjs",
  "types": "types/index.d.ts",
  "unpkg": "dist-sdk/dot-ocean.js",
  "jsdelivr": "dist-sdk/dot-ocean.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist-sdk/dot-ocean.mjs",
      "default": "./dist-sdk/dot-ocean.js"
    }
  },
  "files": [
    "dist-sdk",
    "types",
    "src"
  ]
}
